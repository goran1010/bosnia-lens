# Frontend environment example
# Copy this file to `.env` and adjust values for your local setup.
# `.env` files are gitignored and should stay local.

# API
VITE_BACKEND_URL=http://localhost:3000

# In production (Netlify), set VITE_BACKEND_URL=/backend
# The /backend/* proxy in netlify.toml forwards requests to the actual backend,
# keeping session cookies first-party and avoiding third-party cookie restrictions.