# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/bosnia-lens
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/test_bosnia-lens

# Token / JWT secrets
ACCESS_TOKEN_SECRET=replace-with-access-token-secret
REFRESH_TOKEN_SECRET=replace-with-refresh-token-secret

# Email Service Configuration (Resend)
RESEND_API_KEY=replace-with-resend-api-key

# Application Configuration
FRONTEND_URL=http://localhost:5173
PORT=3000
COOKIE_SECRET=replace-with-cookie-secret

# OAuth / external client credentials (if used)
CLIENT_ID=replace-with-client-id
CLIENT_SECRET=replace-with-client-secret

NODE_ENV=development