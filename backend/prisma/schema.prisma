// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime

  @@map("sessions")
}

enum role {
  ADMIN
  USER
}

model User {
  id             String                     @id @default(uuid())
  email          String                     @unique
  password       String?
  githubId       String?                    @unique
  role           role                       @default(USER)
  pendingChanges PendingChangesPostalCode[]

  @@map("users")
}

model PendingUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  token     String
  expiresAt DateTime

  @@map("pending_users")
}

enum typeOfChange {
  UPDATE
  DELETE
  CREATE
}

model PendingChangesPostalCode {
  id           String        @id @default(uuid())
  code         Int
  typeOfChange typeOfChange
  city         String
  post         postOperator?
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  createdAt    DateTime      @default(now())

  @@map("pending_changes_postal_code")
}

enum postOperator {
  BH_POSTA
  POSTE_SRP
  HP_MOSTAR
}

model PostalCode {
  code Int           @id
  city String
  post postOperator?

  @@map("postal_codes")
}
